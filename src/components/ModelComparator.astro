---
import { policyModels, comparatorMeta, emailSignup } from '../data/modeli';
---

<section id="modeli" class="mx-auto max-w-6xl px-6 pb-16 lg:px-8 lg:pb-24">
  <!-- Section header -->
  <div class="mb-10 max-w-2xl">
    <p class="eyebrow">{comparatorMeta.eyebrow}</p>
    <h2
      class="font-display mt-3 text-4xl font-semibold tracking-[-0.04em] text-(--color-text) sm:text-5xl"
    >
      {comparatorMeta.title}
    </h2>
  </div>

  <!-- Spectrum bar -->
  <div class="spectrum-wrapper">
    <div class="spectrum-tracks" aria-hidden="true">
      {policyModels.map((model) => <div class="spectrum-track" data-model={model.id}></div>)}
    </div>
    <div class="spectrum-labels">
      <span>{comparatorMeta.scaleLeft}</span>
      <span>{comparatorMeta.scaleRight}</span>
    </div>
  </div>

  <!-- Cards container -->
  <div class="cards-container" id="mc-cards">
    {
      policyModels.map((model, index) => (
        <div
          class="model-card"
          data-index={index}
          data-variant={model.badgeVariant}
          role="button"
          tabindex="0"
          aria-expanded="false"
        >
          <div class="card-header">
            <span class="badge">{model.badge}</span>
            <div class="card-title-row">
              <h3 class="card-title font-display">{model.title}</h3>
              <span class="card-chevron" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path
                    d="M4 6l4 4 4-4"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </div>
          </div>

          <div class="card-body">
            <div class="card-separator" />
            <p class="card-summary">{model.summary}</p>
            <div class="card-details">
              {model.details.map((detail) => (
                <div class="detail-row">
                  <span class="detail-label eyebrow">{detail.label}</span>
                  <p class="detail-value">{detail.value}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <!-- Email signup -->
  <div class="email-panel">
    <h3 class="font-display text-2xl font-semibold tracking-[-0.03em] text-(--color-text)">
      {emailSignup.title}
    </h3>
    <p class="mt-2 text-base leading-7 text-(--color-text-soft)">{emailSignup.body}</p>
    <form class="email-form mt-5" novalidate>
      <input
        type="email"
        placeholder={emailSignup.placeholder}
        class="email-input"
        required
        aria-label="E-poštni naslov"
      />
      <button type="submit" class="button-primary">{emailSignup.button}</button>
    </form>
    <p class="mt-3 text-xs text-(--color-text-muted)">{emailSignup.disclaimer}</p>
  </div>
</section>

<style>
  /* ---- Spectrum bar ---- */
  .spectrum-wrapper {
    margin-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .spectrum-tracks {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.375rem;
  }

  .spectrum-track {
    height: 4px;
    border-radius: 9999px;
    background: var(--color-border);
    transition: background-color 0.4s ease;
  }

  .spectrum-track.is-active {
    background: #f0a000;
  }

  .spectrum-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  /* ---- Cards container ---- */
  .cards-container {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.625rem;
    align-items: start;
    transition: grid-template-columns 0.42s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* ---- Individual card ---- */
  .model-card {
    cursor: pointer;
    padding: 1.125rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: 1.25rem;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.92),
      rgba(255, 251, 245, 0.84)
    );
    box-shadow: var(--shadow-panel);
    transition:
      border-color 0.3s ease,
      box-shadow 0.3s ease;
    outline: none;
    min-width: 0;
  }

  .model-card:focus-visible {
    outline: 2px solid rgba(240, 160, 0, 0.6);
    outline-offset: 2px;
  }

  .model-card:hover {
    box-shadow: 0 20px 50px rgba(111, 79, 25, 0.12);
  }

  .model-card.is-active {
    border-color: rgba(240, 160, 0, 0.5);
    box-shadow:
      0 0 0 1px rgba(240, 160, 0, 0.2),
      0 20px 50px rgba(111, 79, 25, 0.12);
  }

  /* ---- Card header ---- */
  .card-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-height: 4.5rem;
  }

  .badge {
    display: inline-block;
    padding: 0.28rem 0.6rem;
    border-radius: 9999px;
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  [data-variant='red'] .badge {
    background: rgba(220, 50, 50, 0.1);
    color: rgb(160, 30, 30);
  }
  [data-variant='orange'] .badge {
    background: rgba(200, 120, 0, 0.12);
    color: rgb(140, 80, 0);
  }
  [data-variant='teal'] .badge {
    background: rgba(0, 150, 130, 0.11);
    color: rgb(0, 95, 85);
  }
  [data-variant='blue'] .badge {
    background: rgba(50, 110, 210, 0.11);
    color: rgb(30, 65, 165);
  }
  [data-variant='green'] .badge {
    background: rgba(50, 150, 70, 0.11);
    color: rgb(20, 105, 45);
  }

  .card-title-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.25rem;
    overflow: hidden;
  }

  .card-title {
    font-size: 0.975rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }

  .card-chevron {
    flex-shrink: 0;
    color: var(--color-text-muted);
    transition: transform 0.3s ease;
    display: flex;
    align-items: center;
  }

  .model-card.is-active .card-chevron {
    color: #f0a000;
    transform: rotate(180deg);
  }

  /* ---- Card body ---- */
  .card-separator {
    height: 1px;
    background: var(--color-border);
    margin: 0.875rem 0;
  }

  .card-summary {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--color-text-soft);
    margin: 0 0 0.875rem;
  }

  .card-details {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .detail-row {
    padding: 0.6rem 0.8rem;
    border-radius: 0.75rem;
    background: rgba(250, 246, 240, 0.85);
    border: 1px solid rgba(86, 63, 28, 0.1);
  }

  .detail-label {
    display: block;
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    margin-bottom: 0.2rem;
  }

  .detail-value {
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--color-text-soft);
    margin: 0;
  }

  @keyframes bodyReveal {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ---- Desktop collapse/expand ---- */
  @media (min-width: 768px) {
    /* Body hidden by default; only shown on the active card */
    .card-body {
      display: none;
    }

    /* Fade+slide in after the grid has had time to expand (0.25s delay) */
    .model-card.is-active .card-body {
      display: block;
      animation: bodyReveal 0.28s ease 0.22s both;
    }

    .card-chevron {
      display: none;
    }

    .card-header {
      min-height: unset;
    }

    .model-card.is-active .card-details {
      max-height: 55vh;
      overflow-y: auto;
    }

    /* Subtle scrollbar */
    .model-card.is-active .card-details::-webkit-scrollbar {
      width: 4px;
    }
    .model-card.is-active .card-details::-webkit-scrollbar-track {
      background: transparent;
    }
    .model-card.is-active .card-details::-webkit-scrollbar-thumb {
      background: var(--color-border);
      border-radius: 9999px;
    }
  }

  /* ---- Mobile: vertical accordion ---- */
  @media (max-width: 767px) {
    .cards-container {
      grid-template-columns: 1fr !important;
      gap: 0.5rem;
    }

    .card-body {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.38s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .model-card.is-active .card-body {
      max-height: 900px;
    }

    .card-chevron {
      display: flex;
    }
  }

  /* ---- Email signup ---- */
  .email-panel {
    margin-top: 2.5rem;
    padding: 2rem;
    border: 1px solid rgba(86, 63, 28, 0.1);
    border-radius: 1.5rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(250, 244, 236, 0.86));
  }

  .email-form {
    display: flex;
    gap: 0.625rem;
    flex-wrap: wrap;
  }

  .email-input {
    flex: 1 1 220px;
    padding: 0.825rem 1.2rem;
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.88);
    font-size: 0.95rem;
    color: var(--color-text);
    font-family: inherit;
    outline: none;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .email-input::placeholder {
    color: var(--color-text-muted);
  }

  .email-input:focus {
    border-color: rgba(86, 63, 28, 0.32);
    box-shadow: 0 0 0 3px rgba(240, 160, 0, 0.1);
  }
</style>

<script>
  const container = document.getElementById('mc-cards') as HTMLElement;
  const cards = Array.from(container.querySelectorAll<HTMLElement>('.model-card'));
  const tracks = Array.from(document.querySelectorAll<HTMLElement>('.spectrum-track'));

  const N = cards.length;
  const equalCols = Array(N).fill('1fr').join(' ');
  let activeIndex: number | null = null;

  function applyDesktopCols(index: number | null) {
    if (window.innerWidth < 768) return;
    // Always use an inline style so every transition is between two inline values —
    // avoids the CSS-stylesheet → inline-style transition skip on the first click.
    container.style.gridTemplateColumns =
      index === null
        ? equalCols
        : cards.map((_, i) => (i === index ? '3.5fr' : '0.8fr')).join(' ');
  }

  function activate(index: number) {
    const toggling = activeIndex === index;
    activeIndex = toggling ? null : index;

    cards.forEach((card, i) => {
      const isActive = activeIndex === i;
      card.classList.toggle('is-active', isActive);
      card.setAttribute('aria-expanded', isActive ? 'true' : 'false');
    });

    tracks.forEach((t, i) => t.classList.toggle('is-active', activeIndex === i));
    applyDesktopCols(activeIndex);
  }

  cards.forEach((card, i) => {
    card.addEventListener('click', () => activate(i));
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        activate(i);
      }
    });
  });

  // Prime the inline style so the very first click has a value to transition from.
  applyDesktopCols(null);

  window.addEventListener('resize', () => {
    applyDesktopCols(activeIndex);
  });
</script>
