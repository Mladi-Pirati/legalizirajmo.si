---
import { navItems } from "../data/site";

const currentPath = Astro.url.pathname;

const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[rgba(252,248,241,0.82)] backdrop-blur-xl">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4 lg:px-8">
    <a
      href="/"
      class="flex items-center gap-3 rounded-full border border-[var(--color-border)] bg-white/72 px-3 py-2 shadow-[var(--shadow-float)] transition hover:border-[rgba(240,160,0,0.34)] hover:bg-white/92 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--color-accent)]"
    >
      <img
        src="/logo.png"
        alt="Pirati"
        class="h-10 w-auto rounded-full bg-white p-1.5 ring-1 ring-[rgba(86,63,28,0.1)]"
      />
      <div class="hidden sm:block">
        <p class="font-display text-sm font-semibold tracking-[0.24em] text-[var(--color-text)] uppercase">
          Pirati
        </p>
      </div>
    </a>

    <nav aria-label="Glavna navigacija" class="hidden items-center gap-2 md:flex">
      {
        navItems.map((item) => {
          const active = isActive(item.href);

          return (
            <a
              href={item.href}
              aria-current={active ? "page" : undefined}
              class={`rounded-full px-4 py-2 text-sm font-semibold transition ${
                active
                  ? "bg-[rgba(240,160,0,0.18)] text-[var(--color-text)] ring-1 ring-[rgba(240,160,0,0.2)]"
                  : "text-[var(--color-text-soft)] hover:bg-white/75 hover:text-[var(--color-text)]"
              }`}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <details class="mobile-nav relative md:hidden">
      <summary class="flex cursor-pointer list-none items-center gap-2 rounded-full border border-[var(--color-border)] bg-white/72 px-4 py-2 text-sm font-semibold text-[var(--color-text-soft)] shadow-[var(--shadow-float)] transition hover:border-[rgba(240,160,0,0.34)] hover:text-[var(--color-text)]">
        <span class="font-display text-xs tracking-[0.24em] uppercase">Meni</span>
        <span aria-hidden="true" class="text-base leading-none">+</span>
      </summary>

      <div class="absolute top-[calc(100%+0.9rem)] right-0 w-64 rounded-[1.5rem] border border-[var(--color-border)] bg-[rgba(255,252,246,0.96)] p-3 shadow-[var(--shadow-panel)]">
        <nav aria-label="Mobilna navigacija" class="flex flex-col gap-1">
          {
            navItems.map((item) => {
              const active = isActive(item.href);

              return (
                <a
                  href={item.href}
                  aria-current={active ? "page" : undefined}
                  class={`rounded-2xl px-4 py-3 text-sm font-semibold transition ${
                    active
                      ? "bg-[rgba(240,160,0,0.16)] text-[var(--color-text)]"
                      : "text-[var(--color-text-soft)] hover:bg-[rgba(240,160,0,0.08)] hover:text-[var(--color-text)]"
                  }`}
                >
                  {item.label}
                </a>
              );
            })
          }
        </nav>
      </div>
    </details>
  </div>
</header>
