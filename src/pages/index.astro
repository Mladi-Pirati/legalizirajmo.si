---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  homeHighlights,
  homeSections,
} from "../data/site";
---

<BaseLayout
  title="Legalizirajmo, regulirajmo, profitirajmo."
  description="Sodobna, pregledna predstavitev argumentov za popolno legalizacijo in regulacijo konoplje."
>
  <main id="main-content">
    <section class="border-b border-[var(--color-border)]">
      <div class="mx-auto grid max-w-6xl gap-12 px-6 py-14 lg:grid-cols-[minmax(0,1.15fr)_minmax(19rem,0.85fr)] lg:px-8 lg:py-20">
        <div class="space-y-8">
          <div class="space-y-6">
            <h1 class="font-display max-w-4xl text-5xl font-semibold tracking-[-0.05em] text-[var(--color-text)] sm:text-6xl lg:text-7xl">
              Legalizirajmo, regulirajmo, profitirajmo.
            </h1>

            <p class="max-w-3xl text-lg leading-8 text-[var(--color-text-soft)] sm:text-xl">
              Predlog zagovarja jasno, odgovorno in pregledno ureditev področja
              konoplje: manj represije, več javnega nadzora, boljša zaščita
              uporabnikov in več prostora za medicinski, industrijski ter razvojni
              potencial.
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <a class="button-primary" href="/model">Preberi predlog modela</a>
            <a class="button-secondary" href="/zakon">Preberi zakon</a>
          </div>
        </div>

        <aside class="surface-panel p-6 sm:p-8">
          <div class="rounded-[1.45rem] p-8">
            <img
              alt="Pirati"
              class="mx-auto h-auto w-full max-w-[16rem]"
              src="/Pirati_MladiPirati_Logo_3.png"
            />
          </div>

          <div class="mt-7 space-y-4 border-t border-[var(--color-border)] pt-6">
            <p class="eyebrow">Zakaj zdaj</p>
            <p class="text-sm leading-7 text-[var(--color-text-soft)]">
              Reguliran trg pomeni manj črnega trga, boljšo kakovost izdelkov,
              jasne pogoje za pridelavo in več sredstev za preventivo, zdravljenje
              ter raziskave.
            </p>
          </div>
        </aside>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-12 lg:px-8 lg:py-16">
      <div class="grid gap-4 md:grid-cols-3">
        {
          homeHighlights.map((highlight) => (
            <article class="surface-panel p-6 sm:p-7">
              <p class="font-display text-4xl font-semibold tracking-[-0.05em] text-[var(--color-accent)]">
                {highlight.value}
              </p>
              <p class="mt-3 text-sm leading-6 font-semibold text-[var(--color-text)]">
                {highlight.label}
              </p>
              <p class="mt-2 text-sm leading-7 text-[var(--color-text-muted)]">{highlight.detail}</p>
              {highlight.href && (
                <a
                  class="mt-4 inline-block text-xs font-semibold tracking-wide text-[var(--color-accent)] hover:underline"
                  href={highlight.href}
                >
                  Preberi več →
                </a>
              )}
            </article>
          ))
        }
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 pb-16 lg:px-8 lg:pb-24">
      <div class="divide-y divide-[var(--color-border)]">
        {
          homeSections.map((section) => (
            <article class="max-w-4xl py-10" id={section.id}>
              <h2 class="font-display mt-4 text-3xl font-semibold tracking-[-0.04em] text-[var(--color-text)] sm:text-4xl">
                {section.title}
              </h2>
              <p class="mt-4 text-lg leading-8 text-[var(--color-text-soft)]">{section.lead}</p>

              <div class="mt-6 space-y-4 text-base leading-8 text-[var(--color-text-soft)]">
                {section.body.map((paragraph) => <p>{paragraph}</p>)}
              </div>

              {
                section.bullets && (
                  <div class="mt-6 border-l-2 border-[rgba(240,160,0,0.5)] pl-4">
                    <ul class="flex flex-col gap-[0.45rem]">
                      {section.bullets.map((bullet) => (
                        <li class="text-sm leading-6 text-[var(--color-text-soft)] before:mr-[0.45rem] before:font-bold before:text-[var(--color-accent)] before:content-['—']">
                          {bullet}
                        </li>
                      ))}
                    </ul>
                  </div>
                )
              }
            </article>
          ))
        }
      </div>
    </section>

    <section class="border-t border-[var(--color-border)]">
      <div class="mx-auto grid max-w-6xl gap-6 px-6 py-12 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center lg:px-8 lg:py-16">
        <div>
          <p class="eyebrow">Nadaljuj z branjem</p>
          <h2 class="font-display mt-3 text-3xl font-semibold tracking-[-0.04em] text-[var(--color-text)]">
            Podrobnosti so razdelane v predlogu modela in v predlogu zakona.
          </h2>
        </div>

        <div class="flex flex-wrap gap-3">
          <a class="button-primary" href="/model">Predlog modela</a>
          <a class="button-secondary" href="/zakon">Predlog zakona</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
