---
import BaseLayout from "../layouts/BaseLayout.astro";
import ModelComparator from "../components/ModelComparator.astro";
import NewsletterSignup from "../components/NewsletterSignup.astro";

const newsletterSubscribeEndpoint = import.meta.env.NEWSLETTER_SUBSCRIBE_ENDPOINT?.trim();
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY?.trim();

if (!newsletterSubscribeEndpoint) {
  throw new Error(
    "Missing required NEWSLETTER_SUBSCRIBE_ENDPOINT environment variable. Add it to .env or your build environment."
  );
}

if (!turnstileSiteKey) {
  throw new Error(
    "Missing required PUBLIC_TURNSTILE_SITE_KEY environment variable. Add it to .env or your build environment."
  );
}
---

<BaseLayout
  title="Legalizirajmo, regulirajmo, profitirajmo."
  description="Sodobna, pregledna predstavitev argumentov za popolno legalizacijo in regulacijo konoplje."
>
  <main
    id="main-content"
    data-newsletter-endpoint={newsletterSubscribeEndpoint}
    data-turnstile-site-key={turnstileSiteKey}
  >
    <section class="border-b border-(--color-border) mb-14">
      <div class="mx-auto grid max-w-6xl gap-12 px-6 py-14 lg:grid-cols-[minmax(0,1.15fr)_minmax(19rem,0.85fr)] lg:px-8 lg:py-20">
        <div class="space-y-8">
          <div class="space-y-6">
            <h1 class="font-display max-w-4xl text-5xl font-semibold tracking-[-0.05em] text-(--color-text) sm:text-6xl lg:text-7xl">
              Legalizirajmo, regulirajmo, profitirajmo.
            </h1>

            <p class="max-w-3xl text-lg leading-8 text-(--color-text-soft) sm:text-xl">
              Zagovarjamo jasno, odgovorno in pregledno ureditev področja
              konoplje: manj represije, več javnega nadzora, boljša zaščita
              uporabnikov in več prostora za industrijski ter razvojni
              potencial.
            </p>
          </div>

          <NewsletterSignup variant="hero" />
        </div>

        <aside class="surface-panel p-6 sm:p-8">
          <div class="rounded-[1.45rem] p-8">
            <img
              alt="Pirati"
              class="mx-auto h-auto w-full max-w-[16rem]"
              src="/logo.png"
            />
          </div>

          <div class="mt-7 space-y-4 border-t border-(--color-border) pt-6">
            <p class="eyebrow">Zakaj zdaj</p>
            <p class="text-sm leading-7 text-(--color-text-soft)">
              Reguliran trg pomeni manj črnega trga, boljšo kakovost izdelkov,
              jasne pogoje za pridelavo in več sredstev za preventivo, zdravljenje
              ter raziskave.
            </p>
          </div>
        </aside>
      </div>
    </section>

    <ModelComparator />

    <section class="border-t border-(--color-border)">
      <div class="mx-auto grid max-w-6xl gap-6 px-6 py-12 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center lg:px-8 lg:py-16">
        <div>
          <p class="eyebrow">Nadaljuj z branjem</p>
          <h2 class="font-display mt-3 text-3xl font-semibold tracking-[-0.04em] text-(--color-text)">
            Podrobnosti so razdelane v predlogu modela in v predlogu zakona.
          </h2>
        </div>

        <div class="flex flex-wrap gap-3">
          <a class="button-primary" href="/model">Predlog modela</a>
          <a class="button-secondary" href="/zakon">Predlog zakona</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  type NewsletterFormInstance = {
    form: HTMLFormElement;
    input: HTMLInputElement;
    submit: HTMLButtonElement;
    status: HTMLElement;
    captchaContainer: HTMLElement;
    captchaWidget: HTMLElement;
    captchaToken: string | null;
    captchaWidgetId: string | null;
  };

  type NewsletterStatusState = 'error' | 'info' | 'success' | null;

  type NewsletterErrorPayload = {
    code?: string;
    fieldErrors?: {
      email?: string[];
    };
  };

  type TurnstileRenderOptions = {
    sitekey: string;
    theme?: 'auto' | 'dark' | 'light';
    callback?: (token: string) => void;
    'expired-callback'?: () => void;
    'error-callback'?: () => void;
  };

  type TurnstileApi = {
    render: (container: HTMLElement, options: TurnstileRenderOptions) => string;
    reset: (widgetId?: string) => void;
  };

  type NewsletterWindow = Window &
    typeof globalThis & {
      turnstile?: TurnstileApi;
      __newsletterTurnstileReady__?: () => void;
    };

  const uiMessages = {
    busy: 'Pošiljanje...',
    success: 'Uspešno ste prijavljeni na obvestila.',
    validation: 'Vnesite veljaven e-poštni naslov.',
    duplicate: 'Ta e-poštni naslov je že prijavljen.',
    captchaRequired: 'Za nadaljevanje potrdite, da niste robot.',
    captchaPending: 'Najprej potrdite, da niste robot, nato znova kliknite "Obvestite me".',
    captchaSolved: 'Preverjanje uspešno. Za nadaljevanje znova kliknite "Obvestite me".',
    captchaInvalid: 'Preverjanje je poteklo ali ni uspelo. Poskusite znova.',
    captchaLoadError: 'Varnostnega preverjanja trenutno ni mogoče naložiti. Poskusite znova čez trenutek.',
    rateLimited: 'Prijave so začasno omejene. Poskusite znova malo kasneje.',
    generic: 'Prijave na obvestila trenutno ni mogoče oddati. Poskusite znova kasneje.',
  };

  const turnstileScriptSrc =
    'https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit&onload=__newsletterTurnstileReady__';
  const pageRoot = document.getElementById('main-content');
  const newsletterEndpoint = pageRoot?.dataset.newsletterEndpoint?.trim();
  const turnstileSiteKey = pageRoot?.dataset.turnstileSiteKey?.trim();

  if (pageRoot instanceof HTMLElement && newsletterEndpoint && turnstileSiteKey) {
    const resolvedNewsletterEndpoint = newsletterEndpoint;
    const resolvedTurnstileSiteKey = turnstileSiteKey;
    const newsletterWindow = window as NewsletterWindow;
    const validator = document.createElement('input');
    validator.type = 'email';
    validator.required = true;

    const forms: NewsletterFormInstance[] = Array.from(
      pageRoot.querySelectorAll('form[data-newsletter-form]')
    )
      .map((form): NewsletterFormInstance | null => {
        const input = form.querySelector('[data-newsletter-input]');
        const submit = form.querySelector('[data-newsletter-submit]');
        const status = form.querySelector('[data-newsletter-status]');
        const captchaContainer = form.querySelector('[data-newsletter-captcha]');
        const captchaWidget = form.querySelector('[data-newsletter-captcha-widget]');

        if (
          !(form instanceof HTMLFormElement) ||
          !(input instanceof HTMLInputElement) ||
          !(submit instanceof HTMLButtonElement) ||
          !(status instanceof HTMLElement) ||
          !(captchaContainer instanceof HTMLElement) ||
          !(captchaWidget instanceof HTMLElement)
        ) {
          return null;
        }

        return {
          form,
          input,
          submit,
          status,
          captchaContainer,
          captchaWidget,
          captchaToken: null,
          captchaWidgetId: null,
        };
      })
      .filter((form): form is NewsletterFormInstance => form !== null);

    let isSubscribed = false;
    let isSubmitting = false;
    let captchaRequired = false;
    let turnstileLoader: Promise<TurnstileApi> | null = null;

    function normalizeEmail(value: string): string {
      return value.trim().toLowerCase();
    }

    function isValidEmail(value: string): boolean {
      validator.value = value;
      return validator.checkValidity();
    }

    function setStatus(
      instance: NewsletterFormInstance,
      state: NewsletterStatusState,
      message: string
    ): void {
      instance.status.textContent = message;

      if (state) {
        instance.status.dataset.state = state;
      } else {
        delete instance.status.dataset.state;
      }
    }

    function clearValidation(instance: NewsletterFormInstance): void {
      instance.input.removeAttribute('aria-invalid');
    }

    function markInvalid(instance: NewsletterFormInstance): void {
      instance.input.setAttribute('aria-invalid', 'true');
    }

    function showCaptcha(instance: NewsletterFormInstance, shouldFocus = false): void {
      instance.captchaContainer.hidden = false;

      if (shouldFocus) {
        window.requestAnimationFrame(() => {
          instance.captchaContainer.focus();
        });
      }
    }

    function resetCaptcha(instance: NewsletterFormInstance): void {
      instance.captchaToken = null;

      if (instance.captchaWidgetId && newsletterWindow.turnstile) {
        newsletterWindow.turnstile.reset(instance.captchaWidgetId);
      }
    }

    function setAvailability(instance: NewsletterFormInstance): void {
      const disabled = isSubscribed || isSubmitting;
      const defaultLabel = instance.submit.dataset.defaultLabel || 'Obvestite me';

      instance.form.dataset.busy = isSubmitting ? 'true' : 'false';
      instance.form.dataset.state = isSubscribed ? 'success' : 'idle';
      instance.form.setAttribute('aria-busy', isSubmitting ? 'true' : 'false');
      instance.input.disabled = disabled;
      instance.submit.disabled = disabled;
      instance.submit.textContent = isSubmitting ? uiMessages.busy : defaultLabel;
    }

    function syncAllForms(): void {
      forms.forEach((instance) => {
        clearValidation(instance);
        setAvailability(instance);

        if (isSubscribed) {
          instance.input.value = '';
          instance.captchaContainer.hidden = true;
          instance.captchaToken = null;
          setStatus(instance, 'success', uiMessages.success);
        }
      });
    }

    async function readJsonSafely(
      response: Response
    ): Promise<NewsletterErrorPayload | null> {
      const responseText = await response.text();

      if (!responseText) {
        return null;
      }

      try {
        return JSON.parse(responseText);
      } catch {
        return null;
      }
    }

    function formatRetryAfter(retryAfterValue: string | null): string | null {
      if (!retryAfterValue) {
        return null;
      }

      const seconds = Number(retryAfterValue);

      if (Number.isFinite(seconds)) {
        return formatRelativeDuration(seconds * 1000);
      }

      const retryAt = Date.parse(retryAfterValue);

      if (Number.isNaN(retryAt)) {
        return null;
      }

      return formatRelativeDuration(retryAt - Date.now());
    }

    function formatRelativeDuration(milliseconds: number): string {
      const totalSeconds = Math.max(1, Math.ceil(milliseconds / 1000));

      if (totalSeconds < 60) {
        return `${totalSeconds} s`;
      }

      const totalMinutes = Math.ceil(totalSeconds / 60);

      if (totalMinutes < 60) {
        return `${totalMinutes} min`;
      }

      return `${Math.ceil(totalMinutes / 60)} h`;
    }

    function getRateLimitMessage(retryAfterValue: string | null): string {
      const formattedRetryAfter = formatRetryAfter(retryAfterValue);

      if (!formattedRetryAfter) {
        return uiMessages.rateLimited;
      }

      return `Prijave so začasno omejene. Poskusite znova čez približno ${formattedRetryAfter}.`;
    }

    async function ensureTurnstileReady(): Promise<TurnstileApi> {
      if (newsletterWindow.turnstile) {
        return newsletterWindow.turnstile;
      }

      if (turnstileLoader) {
        return turnstileLoader;
      }

      turnstileLoader = new Promise<TurnstileApi>((resolve, reject) => {
        const handleReady = (): void => {
          delete newsletterWindow.__newsletterTurnstileReady__;

          if (!newsletterWindow.turnstile) {
            turnstileLoader = null;
            reject(new Error('Turnstile API was not initialized.'));
            return;
          }

          resolve(newsletterWindow.turnstile);
        };

        newsletterWindow.__newsletterTurnstileReady__ = handleReady;

        const existingScript = document.querySelector('script[data-newsletter-turnstile-script]');

        if (existingScript instanceof HTMLScriptElement) {
          existingScript.remove();
        }

        const script = document.createElement('script');
        script.src = turnstileScriptSrc;
        script.async = true;
        script.defer = true;
        script.dataset.newsletterTurnstileScript = 'true';
        script.onerror = () => {
          delete newsletterWindow.__newsletterTurnstileReady__;
          turnstileLoader = null;
          reject(new Error('Failed to load Turnstile.'));
        };

        document.head.append(script);
      });

      return turnstileLoader;
    }

    async function ensureCaptcha(
      instance: NewsletterFormInstance,
      options: { focus?: boolean; reset?: boolean } = {}
    ): Promise<boolean> {
      showCaptcha(instance, options.focus);

      try {
        const turnstile = await ensureTurnstileReady();

        if (!instance.captchaWidgetId) {
          instance.captchaWidgetId = turnstile.render(instance.captchaWidget, {
            sitekey: resolvedTurnstileSiteKey,
            theme: 'auto',
            callback: (token: string) => {
              instance.captchaToken = token;
              setStatus(instance, 'info', uiMessages.captchaSolved);
            },
            'expired-callback': () => {
              resetCaptcha(instance);
              setStatus(instance, 'info', uiMessages.captchaInvalid);
            },
            'error-callback': () => {
              instance.captchaToken = null;
              setStatus(instance, 'error', uiMessages.captchaLoadError);
            },
          });
        } else if (options.reset) {
          resetCaptcha(instance);
        }

        if (options.focus) {
          window.requestAnimationFrame(() => {
            instance.captchaContainer.focus();
          });
        }

        return true;
      } catch {
        setStatus(instance, 'error', uiMessages.captchaLoadError);
        return false;
      }
    }

    forms.forEach((instance: NewsletterFormInstance) => {
      setAvailability(instance);

      instance.form.addEventListener('submit', async (event: SubmitEvent) => {
        event.preventDefault();

        if (isSubmitting || isSubscribed) {
          return;
        }

        const normalizedEmail = normalizeEmail(instance.input.value);
        instance.input.value = normalizedEmail;

        forms.forEach((formInstance: NewsletterFormInstance) => {
          clearValidation(formInstance);

          if (!isSubscribed) {
            setStatus(formInstance, null, '');
          }
        });

        if (!isValidEmail(normalizedEmail)) {
          markInvalid(instance);
          setStatus(instance, 'error', uiMessages.validation);
          return;
        }

        if (captchaRequired && !instance.captchaToken) {
          const isChallengeReady = await ensureCaptcha(instance, { focus: true });

          if (isChallengeReady) {
            setStatus(instance, 'info', uiMessages.captchaPending);
          }

          return;
        }

        const captchaToken = captchaRequired ? instance.captchaToken : null;
        const requestBody = captchaToken
          ? { email: normalizedEmail, captchaToken }
          : { email: normalizedEmail };

        isSubmitting = true;
        syncAllForms();

        try {
          const response = await fetch(resolvedNewsletterEndpoint, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(requestBody),
          });

          if (captchaToken) {
            resetCaptcha(instance);
          }

          if (response.status === 204) {
            isSubscribed = true;
            isSubmitting = false;
            syncAllForms();
            return;
          }

          const payload = await readJsonSafely(response);

          isSubmitting = false;
          syncAllForms();

          if (response.status === 429 && payload?.code === 'captcha_required') {
            captchaRequired = true;

            const isChallengeReady = await ensureCaptcha(instance, {
              focus: true,
              reset: false,
            });

            if (isChallengeReady) {
              setStatus(instance, 'info', uiMessages.captchaRequired);
            }

            return;
          }

          if (response.status === 409) {
            markInvalid(instance);
            setStatus(instance, 'error', uiMessages.duplicate);
            return;
          }

          if (response.status === 400 && payload?.code === 'captcha_invalid') {
            captchaRequired = true;

            const isChallengeReady = await ensureCaptcha(instance, {
              focus: true,
              reset: false,
            });

            if (isChallengeReady) {
              setStatus(instance, 'error', uiMessages.captchaInvalid);
            }

            return;
          }

          if (
            response.status === 400 &&
            payload &&
            typeof payload === 'object' &&
            payload.fieldErrors &&
            Array.isArray(payload.fieldErrors.email)
          ) {
            markInvalid(instance);
            setStatus(instance, 'error', uiMessages.validation);
            return;
          }

          if (response.status === 429) {
            setStatus(instance, 'error', getRateLimitMessage(response.headers.get('Retry-After')));
            return;
          }

          setStatus(instance, 'error', uiMessages.generic);
        } catch {
          if (captchaToken) {
            resetCaptcha(instance);
          }

          isSubmitting = false;
          syncAllForms();
          setStatus(instance, 'error', uiMessages.generic);
        }
      });
    });
  }
</script>
